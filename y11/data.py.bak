                    {"conjugation":"you (pl)",       "infinitive_ending":"-bitis","example":"amabitis","tr":"you will love",      "ep":[["am",""],["a","coral"],["bi","yellow"],["tis","blue"]]},
                    {"conjugation":"they",           "infinitive_ending":"-bunt", "example":"amabunt", "tr":"they will love",    "ep":[["am",""],["a","coral"],["bu","yellow"],["nt","blue"]]},
                ],
                "table_note":"Colour key:\n**red** = stem vowel\n**yellow** = tense marker (*-bo-*/*-bi-*/*-bu-*)\n**blue** = person ending",
                "infinitive_ending_header":"Ending"
            }
        ],
        "content":{"questions":QUESTIONS_FUTURE}
